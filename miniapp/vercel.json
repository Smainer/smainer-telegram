{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' 'unsafe-inline' 'unsafe-eval' https: data: blob:; frame-ancestors *;"
        }
      ]
    }
  ],
  "env": {
    "VITE_RELAYER_URL": "https://api.smainer.ai",
    "VITE_STARKNET_RPC_URL": "https://starknet-mainnet.public.blastapi.io", 
    "VITE_SMAINER_CONTRACT_ADDRESS": "REQUIRED_REPLACE_WITH_MAINNET_ADDRESS",
    "VITE_NFT_CONTRACT_ADDRESS": "REQUIRED_REPLACE_WITH_MAINNET_ADDRESS"
  }
}